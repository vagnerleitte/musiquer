{
  "name": "argus-music-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "sync:album-covers": "node scripts/downloadAlbumCovers.mjs",
    "test:e2e": "playwright test && node scripts/summarizeArtifacts.mjs",
    "artifacts:upload": "node scripts/uploadArgusArtifacts.mjs",
    "argus:vercel": "ARGUS_TARGET_URL=https://musiquer.vercel.app npm run test:e2e && npm run artifacts:upload"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}