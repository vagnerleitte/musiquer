# App URL used by automation tools such as Playwright.
# Local development:
ARGUS_TARGET_URL=http://127.0.0.1:5173

# Published Vercel deployment:
# ARGUS_TARGET_URL=https://your-project.vercel.app

# Optional mode flag for scripts that need to branch behavior later.
ARGUS_TARGET_ENV=local

# Required for uploading generated artifacts to Argus.
ARGUS_API_URL=https://api.example.com/artifacts
ARGUS_APPLICATION_ID=musiquer-demo

# Optional overrides. If omitted, Vercel metadata is used when available.
ARGUS_DEPLOYMENT_ID=
ARGUS_EXECUTION_ID=

# Provided by Vercel in build/runtime environments.
VERCEL_GIT_COMMIT_SHA=
VERCEL_DEPLOYMENT_ID=

# Default is true. Set false when the Argus API is available.
ARGUS_MOCK_UPLOAD=true

# Generic CI ZIP upload endpoint.
# Accepted formats:
# API_BASE_URL=http://localhost:3000
# API_BASE_URL=http://localhost:3000/applications
API_BASE_URL=http://localhost:3000/applications
ZIP_PATH=artifacts/bundle/argus-artifacts.zip
APP_NAME=DemoApp
APP_VERSION=1.0.0
APP_DESCRIPTION=Teste
